# Backend environment variables — copy to .env and fill in.

# better-auth + Postgres (Supabase connection string)
DATABASE_URL=
BETTER_AUTH_URL=
FRONTEND_URL=

# Google OAuth (social provider)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Supabase storage backend
USE_SUPABASE=true
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# BYOK (Phase 1): AES-256-GCM key for encrypting user API keys at rest.
# Must decode (base64) to exactly 32 bytes. Generate with:
#   openssl rand -base64 32
# NOTE: changing this invalidates all stored user API keys.
ENCRYPTION_KEY=

# Free tier (owner-funded trial). A signed-in user with no BYOK key gets
# FREE_TIER_LIMIT free AI replies funded by FREE_TIER_KEY, forced onto the cheap
# FREE_TIER_MODEL, then is gated to add their own key. Leave FREE_TIER_KEY blank
# to DISABLE the free tier (reverts to the no_api_key gate on first send).
# FREE_TIER_KEY must match FREE_TIER_PROVIDER (an OpenAI key for openai). Default
# is GPT (gpt-5.4-mini); free replies are capped at 1000 output tokens to bound
# owner spend. FREE_TIER_MODEL must stay cheap and be in the provider allow-list
# (backend/llm/provider.ts) — a non-allow-listed model disables the tier at startup.
FREE_TIER_KEY=
FREE_TIER_PROVIDER=openai
FREE_TIER_MODEL=gpt-5.4-mini
FREE_TIER_LIMIT=5
